# Public application domain. Example: staging.pred-market.com
APP_DOMAIN=staging.example.com
ACME_EMAIL=admin@example.com

# Runtime mode
ENVIRONMENT=staging
COOKIE_SECURE=true
DEMO_SEED_ENABLED=false
PUBLIC_SIGNUP_ENABLED=true
EMAIL_VERIFICATION_REQUIRED=false
ADMIN_MFA_REQUIRED=true

# Same-origin deployment. Keep this equal to https://APP_DOMAIN.
CORS_ORIGINS=https://staging.example.com

# Use AWS RDS PostgreSQL for Phase 2.
DATABASE_URL=postgresql+psycopg://pred_market_app:REPLACE_ME@your-rds-endpoint.amazonaws.com:5432/pred_market

# For Phase 1 staging-only Compose, this can point to redis service.
# For AWS production, use ElastiCache later.
REDIS_URL=redis://redis:6379/0

# Generate with: openssl rand -base64 48
JWT_SECRET_KEY=REPLACE_WITH_LONG_RANDOM_SECRET
MFA_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

# Next.js Railway service. REST is same-origin through the rewrite.
NEXT_PUBLIC_USE_MOCK_DATA=false
NEXT_PUBLIC_USE_DIRECT_API=false
INTERNAL_API_BASE_URL=http://backend.railway.internal:8080
NEXT_PUBLIC_WS_BASE_URL=wss://your-backend.up.railway.app
NEXT_PUBLIC_ENABLE_MARKET_SUGGESTIONS=false
